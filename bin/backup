#!/usr/bin/env bash
# Dump the production Postgres accessory and upload to S3-compatible storage.
# Run on the Hetzner VPS, either via cron or `bin/kamal app exec "bin/backup"`.
#
# Required env:
#   BACKUP_S3_ENDPOINT, BACKUP_S3_BUCKET,
#   BACKUP_S3_ACCESS_KEY, BACKUP_S3_SECRET_KEY
#   DATABASE_URL  (provided inside the app container by Kamal)
#
# Retention: keeps 14 daily + 8 weekly dumps. Adjust RETENTION_* below.

set -euo pipefail

RETENTION_DAILY=14
RETENTION_WEEKLY=8

: "${BACKUP_S3_ENDPOINT:?set BACKUP_S3_ENDPOINT}"
: "${BACKUP_S3_BUCKET:?set BACKUP_S3_BUCKET}"
: "${BACKUP_S3_ACCESS_KEY:?set BACKUP_S3_ACCESS_KEY}"
: "${BACKUP_S3_SECRET_KEY:?set BACKUP_S3_SECRET_KEY}"
: "${DATABASE_URL:?set DATABASE_URL}"

export AWS_ACCESS_KEY_ID="$BACKUP_S3_ACCESS_KEY"
export AWS_SECRET_ACCESS_KEY="$BACKUP_S3_SECRET_KEY"
export AWS_EC2_METADATA_DISABLED=true

timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
filename="cookery-${timestamp}.sql.gz"
tmpfile="/tmp/${filename}"

echo "[backup] pg_dump → ${tmpfile}"
pg_dump --no-owner --no-acl --format=custom "$DATABASE_URL" | gzip -9 > "$tmpfile"

s3url="s3://${BACKUP_S3_BUCKET}/daily/${filename}"
echo "[backup] upload → ${s3url}"
aws --endpoint-url "$BACKUP_S3_ENDPOINT" s3 cp "$tmpfile" "$s3url"

# Promote Sunday dumps to the weekly prefix.
if [ "$(date -u +%u)" = "7" ]; then
  aws --endpoint-url "$BACKUP_S3_ENDPOINT" s3 cp "$s3url" "s3://${BACKUP_S3_BUCKET}/weekly/${filename}"
fi

echo "[backup] prune daily/ (keep ${RETENTION_DAILY})"
aws --endpoint-url "$BACKUP_S3_ENDPOINT" s3 ls "s3://${BACKUP_S3_BUCKET}/daily/" \
  | awk '{print $4}' | sort -r | tail -n +$((RETENTION_DAILY + 1)) \
  | xargs -r -I{} aws --endpoint-url "$BACKUP_S3_ENDPOINT" s3 rm "s3://${BACKUP_S3_BUCKET}/daily/{}"

echo "[backup] prune weekly/ (keep ${RETENTION_WEEKLY})"
aws --endpoint-url "$BACKUP_S3_ENDPOINT" s3 ls "s3://${BACKUP_S3_BUCKET}/weekly/" \
  | awk '{print $4}' | sort -r | tail -n +$((RETENTION_WEEKLY + 1)) \
  | xargs -r -I{} aws --endpoint-url "$BACKUP_S3_ENDPOINT" s3 rm "s3://${BACKUP_S3_BUCKET}/weekly/{}"

rm -f "$tmpfile"
echo "[backup] done"
